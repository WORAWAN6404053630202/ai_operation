# ==============================================
# Restbiz AI — Environment Configuration
# ==============================================

# ----- OpenRouter API -----
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ----- Google Sheets (Optional) -----
# If you want to load data from Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ----- Logging Configuration -----
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# LOG_FORMAT: "human" (colored, readable) or "json" (structured, machine-readable)
# Use "human" for development, "json" for production
LOG_FORMAT=human

# LOG_FILE: Optional file path to write logs (leave empty to disable)
LOG_FILE=

# ----- Server Configuration -----
# Port for FastAPI server
PORT=3000

# Host (0.0.0.0 for production, 127.0.0.1 for local only)
HOST=0.0.0.0

# Workers (for production deployment)
WORKERS=2

# ----- Session Configuration -----
# Session retention in days
SESSION_RETENTION_DAYS=7

# ----- Vector Store Configuration -----
# ChromaDB persistence directory
CHROMA_PERSIST_DIR=./local_chroma_v2

# Embeddings model
EMBEDDINGS_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ----- Development Settings -----
# Enable debug mode (more verbose logging, X-Response-Time header)
DEBUG=false

# Reload on file changes (uvicorn --reload)
RELOAD=false

# ----- Monitoring (Optional) -----
# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# Prometheus metrics endpoint (enabled by default at /api/monitoring/metrics/prometheus)
ENABLE_METRICS=true
